      <Placemark>
        <name>Wearyall Hill</name>
        <description><![CDATA[<img src="https://lh3.googleusercontent.com/umsh/AN6v0v7SiKWCH_g5Jk1T4lLHgZt2A4RNUxOH4gE9lzAzGNuCQ8zdhOoaNNeEBp9CEkZN4MzKBhJczjJhDUAdONQxzm1wbtcFpJElN2wmXKZCCU9nmbcT_z_FvL0yOq4g_RVCNu7V52dtf3A_bjB9" height="200" width="auto" /><br><br>The view from Wearyal Hill as the Michael current approaches Glastonbury. This is painted from the site of the thorn tree. ]]></description>
        <styleUrl>#icon-503-DB4436-labelson</styleUrl>
        <ExtendedData>
          <Data name="gx_media_links">
            <value>https://lh3.googleusercontent.com/umsh/AN6v0v7SiKWCH_g5Jk1T4lLHgZt2A4RNUxOH4gE9lzAzGNuCQ8zdhOoaNNeEBp9CEkZN4MzKBhJczjJhDUAdONQxzm1wbtcFpJElN2wmXKZCCU9nmbcT_z_FvL0yOq4g_RVCNu7V52dtf3A_bjB9</value>
