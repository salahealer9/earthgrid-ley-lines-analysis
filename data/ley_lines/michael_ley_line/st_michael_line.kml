      <Placemark>
        <name>Avebury 2</name>
        <description><![CDATA[<img src="https://lh3.googleusercontent.com/umsh/AN6v0v50CCnCnqC5W0ffot3bAbFupKBGfPvTUibUiRDxu4fpC2uGWsGAehNrFHshqZ92rdqPlToOv9CVwzBDaD8GgUIN_HSLOiWnbGj2DeTv9bjf3P0" height="200" width="auto" /><br><br>Symbolically, the chapel was built out of broken up megaliths.]]></description>
        <styleUrl>#icon-503-DB4436-labelson</styleUrl>
        <ExtendedData>
          <Data name="gx_media_links">
            <value>https://lh3.googleusercontent.com/umsh/AN6v0v50CCnCnqC5W0ffot3bAbFupKBGfPvTUibUiRDxu4fpC2uGWsGAehNrFHshqZ92rdqPlToOv9CVwzBDaD8GgUIN_HSLOiWnbGj2DeTv9bjf3P0</value>
